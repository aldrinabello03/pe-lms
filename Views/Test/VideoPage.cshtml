@{
    ViewData["Title"] = ViewData["Title"] ?? "Dynamic Video Page";
    var videoPath = ViewData["VideoPath"] as string;
    var description = ViewData["Description"] as string;
    var details = ViewData["Details"] as string;
}
<main class="container d-flex justify-content-center align-items-center flex-column bg-image">
    <section class="d-flex p-2 align-items-center justify-content-between w-100 mb-3 border-bottom">
        <div class="d-flex align-items-center">
            @Html.Partial("_NavToggle")
            <span class="fs-4">@ViewBag.Title - Test Video Process</span>
        </div>
        <div class="d-flex align-items-center">
            @Html.ActionLink("Save and Exit", "Index", "Home", null, new { @class = "btn btn-outline-secondary" })
        </div>
    </section>
    <div class="container-fluid w-75">
        <div class="d-flex justify-content-between align-content-center w-100 box-styles">
            <h2 class="mb-3">@ViewData["Title"]</h2>
            <hr class="hr" />
            <div class="form-group d-flex align-items-center">
                <input type="number" class="form-control" id="VideoScore" placeholder="" style="width: 3rem;">
                <label for="VideoScore" class="px-3 mb-0">/10</label>
            </div>
        </div>
        <div class="card mb-3">
            <video src="@videoPath" class="card-img-top" controls autoplay loop></video>
        </div>
        <hr />
        <div class="card mb-3"
             style="
                border: 1px solid rgba(0, 25, 230, 0.4);
                -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33);
                -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33);
                box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);
             ">
            <div class="card-body d-flex">
                <div class="vr"></div>
                <p class="px-4">@details</p>
            </div>
        </div>
        <div class="card mb-3"
             style="
                border: 1px solid rgba(0, 25, 230, 0.4);
                -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33);
                -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33);
                box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);
             ">
            <div class="card-body d-flex">
                <div class="vr"></div>
                <p class="px-4">@description</p>
            </div>
        </div>
        <div class="d-flex w-100 justify-content-between">
            <button class="btn btn-outline-primary bg-b mb-3" type="button" onclick="location.href='@Url.Action("VideoPage", "Test", new { page = ViewData["PreviousPage"] })'">
                Go back to the previous video
            </button>
            <button class="btn btn-outline-primary bg-b mb-3" type="button" onclick="location.href='@Url.Action("VideoPage", "Test", new { page = ViewData["NextPage"] })'">
                Go to next exercise
            </button>
        </div>
    </div>
</main>
