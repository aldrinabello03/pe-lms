@model PELMS.Models.ViewModels.StudentScoreViewModel

@{
    ViewData["Title"] = ViewData["Title"] ?? "Dynamic Video Page";
    var videoPath = ViewData["VideoPath"] as string;
    var purpose = ViewData["Purpose"] as string;
    var formula = ViewData["Formula"] as string;
    var equipment = ViewData["Equipment"] as string;
    var scoring = ViewData["Scoring"] as string;
    var procedureTester = ViewData["ProcedureTester"] as string;
    var procedurePartner = ViewData["ProcedurePartner"] as string;
}

<main class="container d-flex justify-content-center align-items-center flex-column bg-image">
    <section class="d-flex p-2 align-items-center justify-content-between w-100 mb-3 border-bottom">
        <div class="d-flex align-items-center">
            @Html.Partial("_NavToggle")
            <span class="fs-4">@ViewBag.Title</span>
        </div>
    </section>

    <div class="container-fluid w-75">
        <hr />

        <!-- Video Section -->
        @if (!string.IsNullOrEmpty(videoPath))
        {
            <div class="card mb-3">
                <video src="@videoPath" class="card-img-top" controls autoplay loop></video>
            </div>
        }

        <hr />

        <div class="row gx-2">
            <!-- Purpose Card -->
            @if (!string.IsNullOrEmpty(purpose))
            {
                <div class="col">
                    <div class="card mb-3"
                         style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                        <div class="card-body">
                            <h5 class="card-title">Purpose</h5>
                            <p class="card-text">@purpose</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Purpose Card -->
            @if (!string.IsNullOrEmpty(formula))
            {
                <div class="col">
                    <div class="card mb-3"
                         style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                        <div class="card-body">
                            <h5 class="card-title">Formula</h5>
                            <p class="card-text">@formula</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Equipment Card -->
            @if (!string.IsNullOrEmpty(equipment))
            {
                <div class="col">
                    <div class="card mb-3"
                         style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                        <div class="card-body">
                            <h5 class="card-title">Equipment</h5>
                            <p class="card-text">@equipment</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Procedure Tester Card -->
        @if (!string.IsNullOrEmpty(procedureTester))
        {
            <div class="card mb-3"
                 style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                <div class="card-body">
                    <h5 class="card-title">Procedure (Tester)</h5>
                    <p class="card-text">@Html.Raw(procedureTester)</p>
                </div>
            </div>
        }

        <!-- Procedure Partner Card -->
        @if (!string.IsNullOrEmpty(procedurePartner))
        {
            <div class="card mb-3"
                 style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                <div class="card-body">
                    <h5 class="card-title">Procedure (Partner)</h5>
                    <p class="card-text">@Html.Raw(procedurePartner)</p>
                </div>
            </div>
        }

        <!-- Scoring Card -->
        @if (!string.IsNullOrEmpty(scoring))
        {
            <div class="card mb-3"
                 style="border: 1px solid rgba(0, 25, 230, 0.4); -webkit-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); -moz-box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.33); box-shadow: 6px 0px 66px -3px rgba(0,25,230,0.05);">
                <div class="card-body">
                    <h5 class="card-title">Scoring</h5>
                    <p class="card-text">@Html.Raw(scoring)</p>
                </div>
            </div>
        }



        @using (Html.BeginForm())
        {
            if (Model.IsDone == false)
            {
                if (Model.TestTitle == "Body Mass Index")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.Height, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter your Height in meters" } })
                                <br />
                                @Html.EditorFor(model => model.Weight, new { htmlAttributes = new { @class = "form-control", @placeholder = "Enter your Weight in kilograms" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "3-Minute Step Test")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.BeforeHearthRate, new { htmlAttributes = new { @class = "form-control", @placeholder = "Heart rate before exercise" } })
                                <br />
                                @Html.EditorFor(model => model.AfterHearthRate, new { htmlAttributes = new { @class = "form-control", @placeholder = "Heart rate after the exercise" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Push up")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.NumberOfPushUps, new { htmlAttributes = new { @class = "form-control", @placeholder = "Number of push-ups made" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Basic Plank")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.PlankTime, new { htmlAttributes = new { @class = "form-control", @placeholder = "Plank Time" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Zipper Test")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.ZipperGap, new { htmlAttributes = new { @class = "form-control", @placeholder = "Gap or overlapped measurement" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Sit and Reach")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.SitAndReachFirstTry, new { htmlAttributes = new { @class = "form-control", @placeholder = "First try" } })
                                <br />
                                @Html.EditorFor(model => model.SitAndReachSecondTry, new { htmlAttributes = new { @class = "form-control", @placeholder = "Second try" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Juggling")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.JugglingHits, new { htmlAttributes = new { @class = "form-control", @placeholder = "Highest Score" } })
                            </div>
                        </div>
                    </div>
                }
                // insert hexagon
                else if (Model.TestTitle == "40-Meter Sprint")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.SprintTime, new { htmlAttributes = new { @class = "form-control", @placeholder = "Time" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Standing Long Jump")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.LongJumpFirstTry, new { htmlAttributes = new { @class = "form-control", @placeholder = "First try" } })
                                <br />
                                @Html.EditorFor(model => model.LongJumpSecondTry, new { htmlAttributes = new { @class = "form-control", @placeholder = "Second try" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Stork Balance Stand Test")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.BalanceRight, new { htmlAttributes = new { @class = "form-control", @placeholder = "Right foot" } })
                                <br />
                                @Html.EditorFor(model => model.BalanceLeft, new { htmlAttributes = new { @class = "form-control", @placeholder = "Left foot" } })
                            </div>
                        </div>
                    </div>
                }
                else if (Model.TestTitle == "Stick Drop Test")
                {
                    <div class="col">
                        <div class="mb-3 w-25">
                            <div class="card-body">
                                @Html.EditorFor(model => model.StickDrop1, new { htmlAttributes = new { @class = "form-control", @placeholder = "Test 1" } })
                                <br />
                                @Html.EditorFor(model => model.StickDrop2, new { htmlAttributes = new { @class = "form-control", @placeholder = "Test 2" } })
                                <br />
                                @Html.EditorFor(model => model.StickDrop3, new { htmlAttributes = new { @class = "form-control", @placeholder = "Test 3" } })
                            </div>
                        </div>
                    </div>
                }

                <div class="form-group d-flex align-items-center">
                    @Html.HiddenFor(model => model.TestTitle)
                    @Html.HiddenFor(model => model.NextPage)
                </div>

                <button class="btn btn-outline-primary bg-b mb-3" type="submit">SUBMIT</button>
            }
        }

        <!-- Navigation Buttons -->
        <div class="d-flex w-100 justify-content-between">
            <button class="btn btn-outline-primary bg-b mb-3" type="button"
                    onclick="location.href='@Url.Action("VideoPage", "Test", new { page = ViewData["PreviousPage"] })'">
                << Previous exercise
            </button>

            <button class="btn btn-outline-primary bg-b mb-3" type="button"
                    onclick="location.href='@Url.Action("VideoPage", "Test", new { page = ViewData["NextPage"] })'">
                Next exercise >>
            </button>
        </div>

    </div>
</main>
